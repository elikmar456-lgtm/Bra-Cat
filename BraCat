<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BraCat | Доска объявлений</title>
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;700&family=Montserrat+Alternates:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-dark: #0a1628;
            --bg-card: #0f1f38;
            --accent: #1e90ff;
            --accent-glow: #4da6ff;
            --text: #e8edf5;
            --text-secondary: #8ba4c7;
            --danger: #ff4757;
            --success: #2ed573;
            --gold: #ffa502;
            --border: rgba(30, 144, 255, 0.2);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Comfortaa', cursive;
            background: var(--bg-dark);
            background-image:
                radial-gradient(ellipse at 20% 50%, rgba(30, 144, 255, 0.08) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 20%, rgba(0, 100, 200, 0.06) 0%, transparent 50%),
                radial-gradient(ellipse at 50% 80%, rgba(0, 150, 255, 0.05) 0%, transparent 50%);
            min-height: 100vh;
            color: var(--text);
            position: relative;
            overflow-x: hidden;
        }

        /* ========== ПАДАЮЩИЕ ЛИСТИКИ ========== */
        .leaves-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
        }

        .leaf {
            position: absolute;
            top: -50px;
            opacity: 0.7;
            animation: fall linear infinite;
            pointer-events: none;
            font-size: 24px;
        }

        @keyframes fall {
            0% {
                transform: translateY(-50px) rotate(0deg) translateX(0);
                opacity: 0;
            }
            10% {
                opacity: 0.7;
            }
            90% {
                opacity: 0.7;
            }
            100% {
                transform: translateY(100vh) rotate(720deg) translateX(100px);
                opacity: 0;
            }
        }

        .leaf:nth-child(3n) { animation-duration: 8s; animation-delay: 0s; }
        .leaf:nth-child(3n+1) { animation-duration: 10s; animation-delay: 2s; }
        .leaf:nth-child(3n+2) { animation-duration: 12s; animation-delay: 4s; }
        .leaf:nth-child(even) { font-size: 20px; }
        .leaf:nth-child(odd) { font-size: 28px; }

        /* LOGIN OVERLAY */
        .login-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(5, 10, 25, 0.97);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 1000;
            backdrop-filter: blur(10px);
        }

        .login-overlay.hidden { display: none; }

        .login-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 30px;
            padding: 50px 40px;
            text-align: center;
            max-width: 440px;
            width: 90%;
            box-shadow: 0 25px 80px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(30, 144, 255, 0.15);
            position: relative;
            z-index: 1001;
        }

        .login-icon {
            font-size: 55px;
            margin-bottom: 20px;
        }

        .login-title {
            font-family: 'Montserrat Alternates', sans-serif;
            font-size: 26px;
            font-weight: 700;
            background: linear-gradient(135deg, #4da6ff, #a0d2ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 12px;
        }

        .login-subtitle {
            color: var(--text-secondary);
            font-size: 14px;
            margin-bottom: 35px;
            line-height: 1.6;
        }

        .code-input-wrapper {
            position: relative;
            margin-bottom: 25px;
        }

        .code-input {
            width: 100%;
            padding: 18px 20px;
            background: rgba(10, 22, 40, 0.8);
            border: 2px solid var(--border);
            border-radius: 20px;
            color: #fff;
            font-size: 18px;
            font-family: 'Montserrat Alternates', sans-serif;
            text-align: center;
            letter-spacing: 8px;
            outline: none;
            transition: all 0.4s ease;
        }

        .code-input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 35px rgba(30, 144, 255, 0.3);
        }

        .code-input::placeholder {
            color: #3a5070;
            letter-spacing: 2px;
            font-size: 14px;
        }

        /* ========== НЕОБЫЧНЫЕ КНОПКИ ========== */
        .btn {
            width: 100%;
            padding: 16px;
            border: none;
            border-radius: 20px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            font-family: 'Montserrat Alternates', sans-serif;
            letter-spacing: 1px;
            position: relative;
            overflow: hidden;
            margin-bottom: 12px;
            text-transform: uppercase;
        }

        /* Кнопка админа - неоновая */
        .btn-admin {
            background: linear-gradient(135deg, #1e90ff, #0077ea);
            color: #fff;
            box-shadow: 0 8px 30px rgba(30, 144, 255, 0.35);
            animation: neonPulse 2s infinite;
        }

        .btn-admin::before {
            content: '';
            position: absolute;
            top: -2px;
            left: -2px;
            right: -2px;
            bottom: -2px;
            background: linear-gradient(45deg, #1e90ff, #00ffff, #1e90ff, #0066ff);
            border-radius: 22px;
            z-index: -1;
            animation: borderGlow 3s linear infinite;
            background-size: 300% 300%;
        }

        @keyframes neonPulse {
            0%, 100% { box-shadow: 0 8px 30px rgba(30, 144, 255, 0.35); }
            50% { box-shadow: 0 8px 50px rgba(30, 144, 255, 0.7), 0 0 80px rgba(0, 150, 255, 0.3); }
        }

        @keyframes borderGlow {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .btn-admin:hover {
            transform: translateY(-3px);
        }

        /* Кнопка гостя - стеклянная */
        .btn-guest {
            background: rgba(30, 144, 255, 0.05);
            color: var(--accent-glow);
            border: 2px solid rgba(30, 144, 255, 0.4);
            backdrop-filter: blur(10px);
        }

        .btn-guest::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(45deg, transparent, rgba(30, 144, 255, 0.1), transparent);
            transform: rotate(45deg);
            transition: all 0.6s;
        }

        .btn-guest:hover::after {
            left: 100%;
        }

        .btn-guest:hover {
            transform: translateY(-2px);
            border-color: var(--accent);
            box-shadow: 0 5px 25px rgba(30, 144, 255, 0.2);
        }

        .error-msg {
            color: var(--danger);
            font-size: 13px;
            margin-top: 10px;
            min-height: 20px;
            font-weight: 600;
        }

        /* HEADER */
        .header {
            background: rgba(10, 22, 40, 0.9);
            backdrop-filter: blur(20px);
            padding: 20px 30px;
            text-align: center;
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 100;
            position: relative;
        }

        .header-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            max-width: 1200px;
            margin: 0 auto;
        }

        .logo {
            font-family: 'Montserrat Alternates', sans-serif;
            font-size: 32px;
            font-weight: 700;
            background: linear-gradient(135deg, #4da6ff, #a0d2ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            letter-spacing: 2px;
        }

        .btn-logout {
            background: rgba(255, 71, 87, 0.15);
            border: 1px solid rgba(255, 71, 87, 0.4);
            color: var(--danger);
            padding: 10px 22px;
            border-radius: 14px;
            cursor: pointer;
            font-family: 'Montserrat Alternates', sans-serif;
            font-weight: 600;
            font-size: 13px;
            transition: all 0.3s;
            letter-spacing: 1px;
            position: relative;
            overflow: hidden;
        }

        .btn-logout::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,71,87,0.2), transparent);
            transition: left 0.5s;
        }

        .btn-logout:hover::before {
            left: 100%;
        }

        .btn-logout:hover {
            background: rgba(255, 71, 87, 0.25);
            box-shadow: 0 5px 20px rgba(255, 71, 87, 0.4);
            transform: translateY(-2px);
        }

        /* MAIN */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 30px 20px;
            position: relative;
            z-index: 1;
        }

        .section-title {
            font-family: 'Montserrat Alternates', sans-serif;
            font-size: 22px;
            font-weight: 600;
            margin-bottom: 25px;
            color: var(--accent-glow);
            text-align: center;
            letter-spacing: 1px;
        }

        /* ADD PRODUCT FORM */
        .add-product-form {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 28px;
            padding: 35px 30px;
            margin-bottom: 40px;
            box-shadow: 0 15px 50px rgba(0, 0, 0, 0.3);
            display: none;
        }
        .add-product-form.visible {
            display: block;
            animation: slideDown 0.5s ease;
        }
        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }
        @media (max-width: 768px) {
            .form-grid { grid-template-columns: 1fr; }
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .form-group.full { grid-column: 1 / -1; }
        .form-group label {
            font-size: 13px;
            color: var(--accent-glow);
            font-weight: 600;
            letter-spacing: 1px;
        }
        .form-group input,
        .form-group textarea {
            padding: 14px 18px;
            background: rgba(10, 22, 40, 0.7);
            border: 2px solid var(--border);
            border-radius: 16px;
            color: #fff;
            font-family: 'Comfortaa', cursive;
            font-size: 15px;
            outline: none;
            transition: all 0.4s;
            resize: vertical;
        }
        .form-group input:focus,
        .form-group textarea:focus {
            border-color: var(--accent);
            box-shadow: 0 0 25px rgba(30, 144, 255, 0.2);
        }

        /* Кнопка публикации - радужная */
        .btn-submit {
            background: linear-gradient(135deg, #2ed573, #1abc4a);
            color: #fff;
            padding: 16px 35px;
            border: none;
            border-radius: 20px;
            font-family: 'Montserrat Alternates', sans-serif;
            font-weight: 600;
            font-size: 15px;
            cursor: pointer;
            letter-spacing: 1px;
            transition: all 0.4s;
            position: relative;
            overflow: hidden;
            grid-column: 1 / -1;
            justify-self: center;
        }

        .btn-submit::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            transition: left 0.5s;
        }

        .btn-submit:hover::before {
            left: 100%;
        }

        .btn-submit:hover {
            transform: translateY(-3px);
            box-shadow: 0 14px 40px rgba(46, 213, 115, 0.6);
        }

        /* PRODUCTS GRID */
        .products-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 25px;
        }

        .product-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 24px;
            overflow: hidden;
            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
        }
        .product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 25px 60px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(30, 144, 255, 0.3);
        }

        .product-image {
            width: 100%;
            height: 240px;
            object-fit: cover;
            border-bottom: 1px solid var(--border);
        }
        .product-no-image {
            width: 100%;
            height: 240px;
            background: linear-gradient(135deg, rgba(30, 144, 255, 0.1), rgba(0, 100, 200, 0.2));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 60px;
            color: rgba(30, 144, 255, 0.3);
        }

        .product-body { padding: 20px; }
        .product-name {
            font-family: 'Montserrat Alternates', sans-serif;
            font-size: 18px;
            font-weight: 600;
            color: #fff;
            margin-bottom: 8px;
        }
        .product-price {
            font-family: 'Montserrat Alternates', sans-serif;
            font-size: 24px;
            font-weight: 700;
            background: linear-gradient(135deg, #ffa502, #ff6b35);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 10px;
        }
        .product-desc {
            color: var(--text-secondary);
            font-size: 13px;
            line-height: 1.5;
            margin-bottom: 15px;
        }

        .btn-delete {
            background: rgba(255, 71, 87, 0.15);
            border: 1px solid rgba(255, 71, 87, 0.4);
            color: var(--danger);
            padding: 8px 16px;
            border-radius: 12px;
            cursor: pointer;
            font-family: 'Montserrat Alternates', sans-serif;
            font-size: 12px;
            font-weight: 600;
            transition: all 0.3s;
            letter-spacing: 1px;
        }
        .btn-delete:hover { background: rgba(255, 71, 87, 0.3); }

        /* FOOTER */
        .footer {
            text-align: center;
            padding: 35px 20px;
            border-top: 1px solid var(--border);
            margin-top: 50px;
            background: rgba(10, 22, 40, 0.9);
            backdrop-filter: blur(10px);
            position: relative;
            z-index: 1;
        }
        .footer-content {
            display: inline-flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
            background: rgba(30, 144, 255, 0.08);
            padding: 25px 40px;
            border-radius: 25px;
            border: 1px solid var(--border);
        }
        .footer-text {
            font-family: 'Montserrat Alternates', sans-serif;
            font-size: 18px;
            font-weight: 600;
            color: var(--accent-glow);
            letter-spacing: 1px;
        }
        .footer-phone {
            font-family: 'Montserrat Alternates', sans-serif;
            font-size: 24px;
            font-weight: 700;
            background: linear-gradient(135deg, #4da6ff, #a0d2ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            letter-spacing: 2px;
        }
        .footer-note {
            color: #ffa502;
            font-weight: 700;
            font-size: 14px;
            letter-spacing: 1px;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: var(--text-secondary);
            grid-column: 1 / -1;
            font-size: 18px;
        }
        .empty-state span {
            font-size: 60px;
            display: block;
            margin-bottom: 15px;
        }

        /* TOAST */
        .toast {
            position: fixed;
            top: 25px;
            right: 25px;
            background: rgba(15, 31, 56, 0.95);
            border: 1px solid rgba(30, 144, 255, 0.3);
            color: #fff;
            padding: 16px 28px;
            border-radius: 18px;
            z-index: 9999;
            font-family: 'Montserrat Alternates', sans-serif;
            font-weight: 600;
            font-size: 14px;
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.5);
            animation: slideIn 0.4s ease;
            backdrop-filter: blur(15px);
            letter-spacing: 0.5px;
        }

        @keyframes slideIn {
            from { transform: translateX(120%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
    </style>
</head>
<body>

    <!-- ПАДАЮЩИЕ ЛИСТИКИ -->
    <div class="leaves-container" id="leavesContainer"></div>

    <!-- LOGIN OVERLAY -->
    <div class="login-overlay" id="loginOverlay">
        <div class="login-card">
            <div class="login-icon">🐱</div>
            <div class="login-title">BraCat</div>
            <div class="login-subtitle">Введите код доступа или войдите как гость</div>
            <div class="code-input-wrapper">
                <input type="password" class="code-input" id="codeInput" placeholder="Введите код" maxlength="12">
            </div>
            <button class="btn btn-admin" onclick="loginAsAdmin()">✅ Подтвердить</button>
            <button class="btn btn-guest" onclick="loginAsGuest()">👤 Я не админ</button>
            <div class="error-msg" id="loginError"></div>
        </div>
    </div>

    <!-- HEADER -->
    <header class="header">
        <div class="header-top">
            <div class="logo">🐱 BraCat</div>
            <button class="btn-logout" onclick="logout()">🚪 Выйти</button>
        </div>
    </header>

    <!-- MAIN CONTENT -->
    <div class="container">
        <div class="add-product-form" id="addProductForm">
            <div class="section-title">📦 Добавить новый товар</div>
            <div class="form-grid">
                <div class="form-group">
                    <label>📸 Фото товара</label>
                    <input type="file" id="productImage" accept="image/*">
                </div>
                <div class="form-group">
                    <label>🏷️ Название товара</label>
                    <input type="text" id="productName" placeholder="Например: iPhone 15 Pro">
                </div>
                <div class="form-group">
                    <label>💰 Цена (₽)</label>
                    <input type="number" id="productPrice" placeholder="50000">
                </div>
                <div class="form-group">
                    <label>📝 Категория</label>
                    <input type="text" id="productCategory" placeholder="Электроника, Одежда...">
                </div>
                <div class="form-group full">
                    <label>📋 Описание</label>
                    <textarea id="productDesc" rows="3" placeholder="Подробное описание товара..."></textarea>
                </div>
                <button class="btn-submit" onclick="addProduct()">✨ Опубликовать объявление</button>
            </div>
        </div>

        <div class="section-title">🛍️ Мои объявления</div>
        <div class="products-grid" id="productsGrid">
            <div class="empty-state">
                <span>📭</span>
                Пока нет объявлений
            </div>
        </div>
    </div>

    <!-- FOOTER -->
    <footer class="footer">
        <div class="footer-content">
            <div class="footer-text">💬 Пишите мне в MAX на этот номер:</div>
            <div class="footer-phone">+7 950 615 16 72</div>
            <div class="footer-note">📱 А не звоните! 🚫📞</div>
        </div>
    </footer>

    <script>
        // ========== ПАДАЮЩИЕ ЛИСТИКИ ==========
        function createLeaves() {
            const container = document.getElementById('leavesContainer');
            const leaves = ['🍁', '🍂', '🍃', '🌿', '🍀', '🍁', '🍂', '🍃', '🌿', '🍀'];
            
            for (let i = 0; i < 30; i++) {
                const leaf = document.createElement('div');
                leaf.className = 'leaf';
                leaf.textContent = leaves[Math.floor(Math.random() * leaves.length)];
                leaf.style.left = Math.random() * 100 + '%';
                leaf.style.animationDelay = Math.random() * 10 + 's';
                leaf.style.animationDuration = (Math.random() * 10 + 8) + 's';
                container.appendChild(leaf);
            }
        }
        
        function addNewLeaf() {
            const container = document.getElementById('leavesContainer');
            const leaves = ['🍁', '🍂', '🍃', '🌿', '🍀'];
            const leaf = document.createElement('div');
            leaf.className = 'leaf';
            leaf.textContent = leaves[Math.floor(Math.random() * leaves.length)];
            leaf.style.left = Math.random() * 100 + '%';
            leaf.style.animationDuration = (Math.random() * 10 + 8) + 's';
            container.appendChild(leaf);
            
            setTimeout(() => {
                leaf.remove();
            }, 15000);
        }
        
        createLeaves();
        setInterval(addNewLeaf, 2000);

        // ========== ОСНОВНОЙ ФУНКЦИОНАЛ ==========
        const ADMIN_CODE = 'klk464946';
        let isAdmin = false;
        let products = [];

        function loadProducts() {
            const saved = localStorage.getItem('bracat_products');
            if (saved) products = JSON.parse(saved);
            renderProducts();
        }

        function saveProducts() {
            localStorage.setItem('bracat_products', JSON.stringify(products));
        }

        function loginAsAdmin() {
            const code = document.getElementById('codeInput').value.trim();
            const errorEl = document.getElementById('loginError');
            if (code === ADMIN_CODE) {
                isAdmin = true;
                document.getElementById('loginOverlay').classList.add('hidden');
                document.getElementById('addProductForm').classList.add('visible');
                errorEl.textContent = '';
                renderProducts();
                showToast('✅ Доступ администратора открыт!');
            } else {
                errorEl.textContent = '❌ Неверный код доступа!';
                document.getElementById('codeInput').style.borderColor = '#ff4757';
                setTimeout(() => {
                    document.getElementById('codeInput').style.borderColor = 'rgba(30, 144, 255, 0.2)';
                }, 1500);
            }
        }

        function loginAsGuest() {
            isAdmin = false;
            document.getElementById('loginOverlay').classList.add('hidden');
            document.getElementById('addProductForm').classList.remove('visible');
            document.getElementById('loginError').textContent = '';
            renderProducts();
            showToast('👤 Вы вошли как гость');
        }

        function logout() {
            isAdmin = false;
            document.getElementById('loginOverlay').classList.remove('hidden');
            document.getElementById('addProductForm').classList.remove('visible');
            document.getElementById('codeInput').value = '';
            document.getElementById('loginError').textContent = '';
            renderProducts();
        }

        document.getElementById('codeInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') loginAsAdmin();
        });

        function addProduct() {
            if (!isAdmin) { showToast('❌ Только администратор может добавлять товары!'); return; }
            const name = document.getElementById('productName').value.trim();
            const price = document.getElementById('productPrice').value.trim();
            const category = document.getElementById('productCategory').value.trim();
            const desc = document.getElementById('productDesc').value.trim();
            const imageInput = document.getElementById('productImage');
            if (!name || !price) { showToast('⚠️ Название и цена обязательны!'); return; }

            if (imageInput.files && imageInput.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    products.unshift({ id: Date.now(), name, price: Number(price), category: category || 'Без категории', desc: desc || '', image: e.target.result, date: new Date().toLocaleDateString('ru-RU') });
                    saveProducts(); renderProducts(); clearForm();
                    showToast('✅ Объявление опубликовано!');
                };
                reader.readAsDataURL(imageInput.files[0]);
            } else {
                products.unshift({ id: Date.now(), name, price: Number(price), category: category || 'Без категории', desc: desc || '', image: null, date: new Date().toLocaleDateString('ru-RU') });
                saveProducts(); renderProducts(); clearForm();
                showToast('✅ Объявление опубликовано!');
            }
        }

        function deleteProduct(id) {
            if (!isAdmin) { showToast('❌ Только администратор может удалять!'); return; }
            if (confirm('Удалить это объявление?')) {
                products = products.filter(p => p.id !== id);
                saveProducts(); renderProducts();
                showToast('🗑️ Объявление удалено');
            }
        }

        function clearForm() {
            document.getElementById('productName').value = '';
            document.getElementById('productPrice').value = '';
            document.getElementById('productCategory').value = '';
            document.getElementById('productDesc').value = '';
            document.getElementById('productImage').value = '';
        }

        function renderProducts() {
            const grid = document.getElementById('productsGrid');
            if (products.length === 0) {
                grid.innerHTML = '<div class="empty-state"><span>📭</span>Пока нет объявлений</div>';
                return;
            }
            grid.innerHTML = products.map(p => `
                <div class="product-card">
                    ${p.image ? `<img src="${p.image}" class="product-image" alt="${p.name}">` : '<div class="product-no-image">📦</div>'}
                    <div class="product-body">
                        <div class="product-name">${p.name}</div>
                        <div class="product-price">${p.price.toLocaleString('ru-RU')} ₽</div>
                        ${p.category ? `<div style="color:#4da6ff;font-size:12px;margin-bottom:5px;">📂 ${p.category}</div>` : ''}
                        ${p.desc ? `<div class="product-desc">${p.desc}</div>` : ''}
                        <div style="display:flex;justify-content:space-between;align-items:center;">
                            <span style="color:#5a7090;font-size:11px;">📅 ${p.date}</span>
                            ${isAdmin ? `<button class="btn-delete" onclick="deleteProduct(${p.id})">🗑️ Удалить</button>` : ''}
                        </div>
                    </div>
                </div>
            `).join('');
        }

        function showToast(message) {
            const existing = document.querySelector('.toast');
            if (existing) existing.remove();
            const toast = document.createElement('div');
            toast.className = 'toast';
            toast.textContent = message;
            document.body.appendChild(toast);
            setTimeout(() => { toast.style.opacity = '0'; toast.style.transition = 'opacity 0.4s'; setTimeout(() => toast.remove(), 400); }, 3000);
        }

        loadProducts();
    </script>
</body>
</html>
